# Production Environment Configuration

# ============================================
# CRITICAL: Set these in production
# ============================================

# OAuth/OIDC Configuration
SSO_ID=your-client-id
SSO_SECRET=your-client-secret
OIDC_BASE=https://your-sso-server.com
OIDC_ISSUER=https://your-sso-server.com
CALLBACK_URL=https://your-backend.com/auth/callback

# Frontend URL (MUST match actual frontend domain)
FRONTEND_URL=https://your-frontend.com

# Secrets (generate strong random strings)
SESSION_SECRET=generate-random-string-here
AUTH_SECRET=generate-random-string-here

# Environment
NODE_ENV=production
PORT=5002

# Session timeout (hours)
SESSION_TIMEOUT_HOURS=24

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# Transparent Screen Lock (Windows only)
TRANSPARENT_LOCK_ENABLED=true
TRANSPARENT_LOCK_SOURCE=Transparent Screen Lock
TRANSPARENT_LOCK_LOG_TYPE=Application
